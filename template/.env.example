# ============================================
# .env.example — Template for environment variables
# ============================================
# Copy this to your agent's home directory and fill
# in your actual API keys.
#
# For Hermes:  cp .env.example ~/.hermes/.env
# For OpenClaw: cp .env.example ~/.openclaw/.env

# ── GitHub (required for backup sync) ───────
# Create a token at https://github.com/settings/tokens/new
# Scopes needed: repo (full control)
GITHUB_TOKEN=ghp_your_token_here

# ── LLM Providers (at least one required) ───
# DeepSeek
DEEPSEEK_API_KEY=sk_your_key_here
# OpenRouter
# OPENROUTER_API_KEY=sk-or-your-key-here
# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# Google Gemini
# GOOGLE_API_KEY=your-key-here

# ── Platform Integration (optional) ─────────
# Telegram Bot
# TELEGRAM_BOT_TOKEN=your-bot-token
# Discord Bot
# DISCORD_BOT_TOKEN=your-bot-token
# Feishu / Lark
# FEISHU_APP_ID=cli_your-id
# FEISHU_APP_SECRET=your-secret

# ── Terminal Configuration (optional) ───────
# TERMINAL_TIMEOUT=180
# TERMINAL_LIFETIME_SECONDS=300
